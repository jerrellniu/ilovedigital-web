# MailerLite — form submissions (audit, contact, newsletter)
# Create a key in MailerLite: Integrations → API. Never commit the real .env.
MAILERLITE_API_KEY=

# MailerLite group IDs. Each group triggers its automation
# (internal notification + auto-reply). Create the groups in MailerLite
# and paste their IDs here.
ML_GROUP_NEWSLETTER=
ML_GROUP_AUDIT=
ML_GROUP_CONTACT=
